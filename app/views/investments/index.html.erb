<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Choose Your Investment Platform</h1>
    
    <div class="grid md:grid-cols-2 gap-6">
      <% @platforms.each do |platform| %>
        <div class="bg-white rounded-lg shadow-md p-6 border border-gray-200 hover:shadow-lg transition-shadow">
          <h2 class="text-xl font-semibold text-gray-900 mb-3"><%= platform.name %></h2>
          
          <div class="mb-4">
            <h3 class="text-sm font-medium text-gray-700 mb-2">Investment Flow:</h3>
            <ul class="text-sm text-gray-600 space-y-1">
              <% platform.steps_ordered.each_with_index do |step, index| %>
                <li class="flex items-center">
                  <span class="w-6 h-6 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-xs font-medium mr-2">
                    <%= index + 1 %>
                  </span>
                  <%= step.title %>
                </li>
              <% end %>
            </ul>
          </div>
          
          <%= link_to "Start Investment", new_platform_investment_path(platform), 
              class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition-colors text-center block" %>
        </div>
      <% end %>
    </div>
  </div>
</div> 