{
  "ruby.useLanguageServer": true,
  "ruby.lint": {
    "rubocop": {
      "useBundler": true
    }
  },
  "ruby.format": "rubocop",
  "ruby.intellisense": "rubyLsp",
  "ruby.debugger": "rdbg",
  "files.associations": {
    "*.rb": "ruby"
  },
  "emmet.includeLanguages": {
    "erb": "html"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/tmp": true,
    "**/log": true
  }
} 